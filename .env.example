# Runtime: pooled Neon connection for app traffic
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-ENDPOINT-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&pgbouncer=true&connection_limit=1"

# Prisma CLI / migrations: direct Neon connection, no PgBouncer
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@YOUR-ENDPOINT.REGION.aws.neon.tech/DBNAME?sslmode=require"
